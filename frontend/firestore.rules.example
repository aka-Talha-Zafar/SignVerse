// Example Firestore security rules — deploy with Firebase CLI: `firebase deploy --only firestore:rules`
// In console: Firestore → Rules. Replace YOUR_PROJECT_ID if needed.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
